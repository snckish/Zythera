CREATE DATABASE IF NOT EXISTS system_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE system_db;

-- USERS TABLE
CREATE TABLE IF NOT EXISTS users (
    email VARCHAR(191) PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    password VARCHAR(255) NOT NULL,
    role ENUM('user', 'admin') DEFAULT 'user',
    profile_pic LONGTEXT DEFAULT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;

-- INVENTORY TABLE (moved up before carts and order_items)
CREATE TABLE IF NOT EXISTS inventory (
    inv_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    size VARCHAR(100) DEFAULT '',
    color VARCHAR(100) DEFAULT '',
    price DECIMAL(10, 2) NOT NULL DEFAULT 0.00,
    description TEXT DEFAULT NULL,
    stock INT NOT NULL DEFAULT 0,
    category VARCHAR(50) DEFAULT 'Sofa',
    image VARCHAR(255) DEFAULT ''
) ENGINE=InnoDB;

-- CARTS TABLE
CREATE TABLE IF NOT EXISTS carts (
    carts_id INT AUTO_INCREMENT PRIMARY KEY,
    email VARCHAR(191) NOT NULL,
    inv_id INT NOT NULL,
    qty INT NOT NULL DEFAULT 1,
    FOREIGN KEY (email) REFERENCES users(email) ON DELETE CASCADE,
    FOREIGN KEY (inv_id) REFERENCES inventory(inv_id) ON DELETE CASCADE,
    UNIQUE KEY unique_user_product (email, inv_id)
) ENGINE=InnoDB;

-- ORDERS TABLE
CREATE TABLE IF NOT EXISTS orders (
    ord_no INT AUTO_INCREMENT PRIMARY KEY,
    order_id VARCHAR(50) NOT NULL UNIQUE,
    email VARCHAR(191) NOT NULL,
    subtotal DECIMAL(10, 2) NOT NULL,
    shipping DECIMAL(10, 2) NOT NULL DEFAULT 150.00,
    total DECIMAL(10, 2) NOT NULL,
    date DATETIME NOT NULL,
    status VARCHAR(50) DEFAULT 'Pending',
    full_name VARCHAR(255) NOT NULL,
    phone VARCHAR(50) NOT NULL,
    address TEXT NOT NULL,
    city VARCHAR(100) NOT NULL,
    province VARCHAR(100) NOT NULL,
    zip VARCHAR(20) NOT NULL,
    pay_method VARCHAR(50) NOT NULL,
    notes TEXT DEFAULT NULL,
    FOREIGN KEY (email) REFERENCES users(email) ON DELETE CASCADE
) ENGINE=InnoDB;

-- ORDER ITEMS TABLE
CREATE TABLE IF NOT EXISTS order_items (
    orderitems_id INT AUTO_INCREMENT PRIMARY KEY,
    ord_no INT NOT NULL,
    inv_id INT NOT NULL,
    product_name VARCHAR(255) NOT NULL,
    price DECIMAL(10, 2) NOT NULL,
    qty INT NOT NULL,
    FOREIGN KEY (ord_no) REFERENCES orders(ord_no) ON DELETE CASCADE,
    FOREIGN KEY (inv_id) REFERENCES inventory(inv_id) ON DELETE CASCADE
) ENGINE=InnoDB;

-- MESSAGES TABLE
CREATE TABLE IF NOT EXISTS messages (
  msg_id INT AUTO_INCREMENT PRIMARY KEY,
  full_name VARCHAR(255) NOT NULL,
  email VARCHAR(191) NOT NULL,
  subject VARCHAR(255) NOT NULL DEFAULT '',
  message TEXT NOT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (email) REFERENCES users(email) ON DELETE CASCADE
) ENGINE=InnoDB;

